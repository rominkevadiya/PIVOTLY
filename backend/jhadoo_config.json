{
  "main_folder": "/home/meetpatel",
  "bin_folder": "/home/meetpatel/.local/share/Trash/jhadoo",
  "targets": [
    {
      "name": "venv",
      "days_threshold": 7,
      "enabled": true
    },
    {
      "name": "node_modules",
      "days_threshold": 14,
      "enabled": true
    },
    {
      "name": "__pycache__",
      "days_threshold": 30,
      "enabled": true
    },
    {
      "name": ".venv",
      "days_threshold": 7,
      "enabled": true
    },
    {
      "name": ".pytest_cache",
      "days_threshold": 30,
      "enabled": false
    },
    {
      "name": "build",
      "days_threshold": 14,
      "enabled": false
    },
    {
      "name": "dist",
      "days_threshold": 14,
      "enabled": false
    },
    {
      "name": ".tox",
      "days_threshold": 30,
      "enabled": false
    },
    {
      "name": "target",
      "days_threshold": 14,
      "enabled": false
    }
  ],
  "safety": {
    "size_threshold_mb": 5000,
    "require_confirmation_above_mb": 500,
    "dry_run": false,
    "backup_mode": false,
    "archive_folder": "/home/meetpatel/.jhadoo_archive"
  },
  "exclusions": [],
  "notifications": {
    "enabled": true,
    "on_completion": true,
    "on_error": true
